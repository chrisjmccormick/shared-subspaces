{
  "model_type": "bert",
  
  "num_hidden_layers": 6,

  "num_dense_layers": 0,
  
  "hidden_size": 256,
  
  "num_attention_heads": 8,
  
  "intermediate_size": 1024,
  
  "max_position_embeddings": 128,
  "max_seq_length": 128,
  "hidden_act": "gelu",
  "hidden_dropout_prob": 0.1,
  "attention_probs_dropout_prob": 0.1,

  "q_lora_rank": 64,
  "kv_lora_rank": 48,
  "o_lora_rank": 64,
  
  "qk_rope_head_dim": 16,
  "v_head_dim": 32,
  "qk_nope_head_dim": 32,

  "fp16": true,
  
  "train_batch_size": 64,
  "eval_batch_size": 64,
  "learning_rate": 5e-4,
  "num_train_epochs": 3,
  
  "mlm_probability": 0.15,
  
  "dataset_name": "wikitext",
  "dataset_config": "wikitext-2-raw-v1",

  "seed": 42,

  "output_dir": "checkpoints/mla",
  
  "use_mla": true,
  
  "output_subspace": false,
  "ffn_decompose": false
}